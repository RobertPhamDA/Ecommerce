APP_ENV=dev
APP_NAME=Ecommerce API
APP_ORIGINS=http://localhost:3000

# Supabase Postgres connection string (Transaction Pooler is OK; use direct connection for Alembic if needed)
DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/postgres

# JWT
JWT_SECRET=change-me
JWT_ALG=HS256
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=60

# Supabase Storage (images)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=change-me
SUPABASE_STORAGE_BUCKET_IMAGES=images

